@page "/credentials/create"
@using Microsoft.AspNetCore.Authorization
@using tinyidp.Business.BusinessEntities
@using tinyidp.Pages.Models
@using Microsoft.AspNetCore.Components
@attribute [Authorize]
@inject ICredentialBusiness CredentialBusiness
@inject NavigationManager Navigation
@inject AuthenticationStateProvider AuthenticationStateProvider

<PageTitle>Credentials Management - TinyIDP</PageTitle>

<h1>Credentials Management</h1>

<div id="error">
    <span class="error">
        @if (credentialCreate != null && credentialCreate.ExceptionMessage != null)
        {
            @credentialCreate.ExceptionMessage
        }
    </span>
</div>

@if (credentialCreate != null && credentialCreate.CanAccess)
{
    <h3>Add credential</h3>
    <div id="add-block" class="shadowbox">
        <EditForm Model="credentialCreate" OnValidSubmit="HandleSubmit" FormName="credentialCreateForm">
            <DataAnnotationsValidator />
            <ValidationSummary />
            
            <table>
                <tr>
                    <td><label for="Ident">Ident</label></td>
                    <td>
                        <div class="form-group">
                            <InputText id="Ident" @bind-Value="credentialCreate.Ident" class="form-control" />
                            <ValidationMessage For="@(() => credentialCreate.Ident)" />
                        </div>
                    </td>
                </tr>
                <tr>
                    <td><label for="Pass">Password</label></td>
                    <td>
                        <div class="form-group">
                            <InputText id="Pass" @bind-Value="credentialCreate.Pass" class="form-control" type="password" />
                            <ValidationMessage For="@(() => credentialCreate.Pass)" />
                        </div>
                    </td>
                </tr>
                <tr>
                    <td><label for="State">State</label></td>
                    <td>
                        <div class="form-group">
                            <InputSelect id="State" @bind-Value="credentialCreate.State" class="form-control">
                                <option value="">Choose a State</option>
                                @foreach (var value in Enum.GetValues<StateCredential>())
                                {
                                    <option value="@value">@value</option>
                                }
                            </InputSelect>
                            <ValidationMessage For="@(() => credentialCreate.State)" />
                        </div>
                    </td>
                </tr>
                <tr>
                    <td><label for="RoleIdent">Role</label></td>
                    <td>
                        <div class="form-group">
                            <select id="RoleIdent" 
                                class="form-control" 
                                @onchange="OnRoleChanged">
                            <option value="">Choose a Role</option>
                            @foreach (RoleCredential value in Enum.GetValues<RoleCredential>())
                            {
                                <option value="@((int)value)" selected="@(credentialCreate.RoleIdent == value)">
                                    @value
                                </option>
                            }
                            </select>
                            <ValidationMessage For="@(() => credentialCreate.RoleIdent)" />
                        </div>
                    </td>
                </tr>
            </table>

            @if (credentialCreate.RoleIdent == RoleCredential.Client)
            {
                <div id="client_div" class="client_id">
                    <table>
                        <tr>
                            <td><label for="NbMaxRenew">Nb max renew</label></td>
                            <td>
                                <div class="form-group">
                                    <InputNumber id="NbMaxRenew" @bind-Value="credentialCreate.NbMaxRenew" class="form-control" />
                                    <ValidationMessage For="@(() => credentialCreate.NbMaxRenew)" />
                                </div>
                            </td>
                        </tr>
                        <tr>
                            <td><label for="TokenMaxMinuteValidity">Max validity of token in min</label></td>
                            <td>
                                <div class="form-group">
                                    <InputNumber id="TokenMaxMinuteValidity" @bind-Value="credentialCreate.TokenMaxMinuteValidity" class="form-control" />
                                    <ValidationMessage For="@(() => credentialCreate.TokenMaxMinuteValidity)" />
                                </div>
                            </td>
                        </tr>
                        <tr>
                            <td><label for="RefreshMaxMinuteValidity">Max validity of refresh token in min</label></td>
                            <td>
                                <div class="form-group">
                                    <InputNumber id="RefreshMaxMinuteValidity" @bind-Value="credentialCreate.RefreshMaxMinuteValidity" class="form-control" />
                                    <ValidationMessage For="@(() => credentialCreate.RefreshMaxMinuteValidity)" />
                                </div>
                            </td>
                        </tr>
                        <tr>
                            <td><label for="AllowedScopes">Allowed Scopes</label></td>
                            <td>
                                <div class="form-group">
                                    <InputText id="AllowedScopes" @bind-Value="credentialCreate.AllowedScopes" class="form-control" />
                                    <ValidationMessage For="@(() => credentialCreate.AllowedScopes)" />
                                </div>
                            </td>
                        </tr>
                        <tr>
                            <td><label for="Audiences">Audiences</label></td>
                            <td>
                                <div class="form-group">
                                    <InputText id="Audiences" @bind-Value="credentialCreate.Audiences" class="form-control" />
                                    <ValidationMessage For="@(() => credentialCreate.Audiences)" />
                                </div>
                            </td>
                        </tr>
                        <tr>
                            <td><label for="RedirectUri">Redirect Uri</label></td>
                            <td>
                                <div class="form-group">
                                    <InputText id="RedirectUri" @bind-Value="credentialCreate.RedirectUri" class="form-control" />
                                    <ValidationMessage For="@(() => credentialCreate.RedirectUri)" />
                                </div>
                            </td>
                        </tr>
                        <tr>
                            <td><label for="KeyType">Algo of Key</label></td>
                            <td>
                                <div class="form-group">
                                    <InputSelect id="KeyType" @bind-Value="credentialCreate.KeyType" class="form-control">
                                        <option value="">Choose an algo</option>
                                        @foreach (var value in Enum.GetValues<AlgoKeyType>())
                                        {
                                            <option value="@value">@value</option>
                                        }
                                    </InputSelect>
                                    <ValidationMessage For="@(() => credentialCreate.KeyType)" />
                                </div>
                            </td>
                        </tr>
                    </table>
                </div>
            }

            <button type="submit" class="btn btn-primary">Create</button>
        </EditForm>
    </div>
}

@code {
    private CredentialCreateModel? credentialCreate;
    private bool isLoading = true;

    protected override async Task OnInitializedAsync()
    {
        credentialCreate = new CredentialCreateModel();
        var authState = await AuthenticationStateProvider.GetAuthenticationStateAsync();
        
        // Assurez-vous que l'extension .Role() renvoie bien RoleCredential.Admin
        if (authState.User.Claims.Role() != RoleCredential.Admin)
        {
            credentialCreate.ExceptionMessage = "You don't have rights to access";
            credentialCreate.CanAccess = false;
        }
        else
        {
            credentialCreate.CanAccess = true;
        }
        
        isLoading = false;
    }

    private async Task HandleSubmit()
    {
        try
        {
            if (credentialCreate != null)
            {
                CredentialBusiness.AddNewCredential(credentialCreate.ToBusiness());
                Navigation.NavigateTo("/credentials");
            }
        }
        catch (Exception ex)
        {
            if (credentialCreate != null)
            {
                credentialCreate.ExceptionMessage = $"{ex.Message} - {ex.InnerException?.Message}";
            }
        }
    }

    private void OnRoleChanged(ChangeEventArgs e)
    {
        if (credentialCreate != null && e.Value != null)
        {
            // On convertit la valeur string reçue en Enum
            if (Enum.TryParse<RoleCredential>(e.Value.ToString(), out var selectedRole))
            {
                credentialCreate.RoleIdent = selectedRole;
                // On force le rafraîchissement
                StateHasChanged();
            }
        }
    }
}
