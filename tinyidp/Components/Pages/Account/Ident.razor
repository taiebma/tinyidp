@page "/account/ident"
@using System.ComponentModel.DataAnnotations
@using System.Web
@using Microsoft.AspNetCore.Antiforgery
@using Microsoft.AspNetCore.WebUtilities
@inject NavigationManager Navigation
@inject ICredentialBusiness CredentialBusiness
@inject ILogger<Ident> Logger
@inject IAntiforgery Antiforgery
@inject IHttpContextAccessor HttpContextAccessor

<PageTitle>Identification - TinyIDP</PageTitle>

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-6">
            <div class="card">
                <div class="card-header bg-primary text-white">
                    <h3 class="mb-0">Identification</h3>
                </div>
                <div class="card-body">
                    @{
                        var uri = new Uri(Navigation.Uri);
                        var hasError = QueryHelpers.ParseQuery(uri.Query).TryGetValue("error", out var errorValue);
                    }

                    @if (hasError)
                    {
                        <div class="alert alert-danger" role="alert">
                            @errorValue
                        </div>
                    }

                    <form method="post" action="/account/ident-handler">
                        <AntiforgeryToken />
                        <input type="hidden" name="scope" value="@Scope" />
                        <input type="hidden" name="state" value="@State" />
                        <input type="hidden" name="client_id" value="@Client_Id" />
                        <input type="hidden" name="code_challenge" value="@Code_Challenge" />
                        <input type="hidden" name="code_challenge_method" value="@Code_Challenge_Method" />
                        <input type="hidden" name="nonce" value="@Nonce" />
                        <input type="hidden" name="redirect_uri" value="@Redirect_Uri" />
                        <div class="mb-3">
                            <label class="form-label">Identifiant</label>
                            <input type="text" name="login" class="form-control" required />
                        </div>

                        <div class="mb-3">
                            <label class="form-label">Mot de passe</label>
                            <input type="password" name="password" class="form-control" required />
                        </div>

                        <div class="d-grid gap-2">
                            <button type="submit" class="btn btn-primary">Connexion</button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@code {
    [SupplyParameterFromQuery]
    public string? Scope { get; set; }

    [SupplyParameterFromQuery]
    public string? State { get; set; }

    [SupplyParameterFromQuery]
    public string? Redirect_Uri { get; set; }

    [SupplyParameterFromQuery]
    public string? Client_Id { get; set; }

    [SupplyParameterFromQuery]
    public string? Code_Challenge { get; set; }

    [SupplyParameterFromQuery]
    public string? Code_Challenge_Method { get; set; }

    [SupplyParameterFromQuery]
    public string? Nonce { get; set; }

