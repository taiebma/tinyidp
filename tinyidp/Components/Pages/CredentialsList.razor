@page "/credentials"
@using Microsoft.AspNetCore.Authorization
@using Microsoft.AspNetCore.Components.Web
@using tinyidp.infrastructure.bdd
@attribute [Authorize]
@inject ICredentialRepository CredentialRepository

<PageTitle>Credentials - TinyIDP</PageTitle>

<div class="container">
    <h1>Gestion des Credentials</h1>
    
    @if (credentials == null)
    {
        <p><em>Chargement...</em></p>
    }
    else if (credentials.Count == 0)
    {
        <p class="alert alert-info">Aucune credential trouvée.</p>
    }
    else
    {
        <table class="table table-striped">
            <thead>
                <tr>
                    <th>ID</th>
                    <th>Ident</th>
                    <th>État</th>
                    <th>Actions</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var cred in credentials)
                {
                    <tr>
                        <td>@cred.Id</td>
                        <td>@cred.Ident</td>
                        <td>@cred.State</td>
                        <td>
                            <a class="btn btn-sm btn-info" href="@($"/credentials/edit/{cred.Id}")">Éditer</a>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    }
</div>

@code {
    private List<Credential>? credentials;

    protected override async Task OnInitializedAsync()
    {
        credentials = await CredentialRepository.GetAll();
    }
}
